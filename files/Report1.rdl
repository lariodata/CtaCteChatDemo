      <Query>
        <DataSourceName>DATOS_PARA_CTACTE</DataSourceName>
        <CommandText>EXEC	 [dbo].[ctacte_armado_sql]
		@suc,
		@nrorep,
		@nrocli,
		@fechacanc,				--pendientes  = NULL ,cancelados desde enero 2003= "2006-01-01"
		@fechadesde,		--"2006-05-01"--qqlowfecha 1900-01-01
		@fechahasta,		-- hoy
		@tablaf = 'DATOS..FACTURAP',
		@tablac = 'DATOS_COBRANZAS..CCMINUTA ',
		@tablar = 'DATOS_COBRANZAS..RECIFACT' ,
		@tablai = 'DATOS_COBRANZAS..INF_RECL',
		@ccDBSQL_pru = ' ',
		@saldini = 0</CommandText>
        <QueryParameters>
          <QueryParameter Name="@suc">
            <Value>=Parameters!suc.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@nrorep">
            <Value>=Parameters!nrorep.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@nrocli">
            <Value>=Parameters!nrocli.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@fechacanc">
            <Value>=Parameters!fechacanc.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@fechadesde">
            <Value>=Parameters!fechadesde.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@fechahasta">
            <Value>=Parameters!fechahasta.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@tablaf">
            <Value>=Parameters!tablaf.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@tablac">
            <Value>=Parameters!tablac.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@tablar">
            <Value>=Parameters!tablar.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@tablai">
            <Value>=Parameters!tablai.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ccDBSQL_pru">
            <Value>=Parameters!ccDBSQL_pru.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@saldini">
            <Value>=Parameters!saldini.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
    </DataSet>
    <DataSet Name="SUCURSALES">
      <Fields>
        <Field Name="NRO">
          <DataField>NRO</DataField>
          <rd:TypeName>System.Int16</rd:TypeName>
        </Field>
        <Field Name="DESCRIP">
          <DataField>DESCRIP</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
      <Query>
        <DataSourceName>DATOS_PARA_CTACTE</DataSourceName>
        <CommandText>SELECT NRO, DESCRIP
FROM DATOS..LARIOSUC</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
    </DataSet>
    <DataSet Name="ZONAS">
      <Fields>
        <Field Name="NROREP">
          <DataField>NROREP</DataField>
          <rd:TypeName>System.Int16</rd:TypeName>
        </Field>
        <Field Name="VRDEN">
          <DataField>VRDEN</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
      <Query>
        <DataSourceName>DATOS_PARA_CTACTE</DataSourceName>
        <CommandText>SELECT NROREP, VRDEN
FROM DATOS..REPRESAS
WHERE SUC  = @suc</CommandText>
        <QueryParameters>
          <QueryParameter Name="@suc">
            <Value>=Parameters!suc.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
    </DataSet>
    <DataSet Name="CLIENTES">
      <Fields>
        <Field Name="NROCLI">
          <DataField>NROCLI</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="VCDEN">
          <DataField>vcden</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
      <Query>
        <DataSourceName>DATOS_PARA_CTACTE</DataSourceName>
        <CommandText>SELECT NROCLI,substring(VCDEN,1,35)+'('+str(nrocli,5)+')' as vcden
FROM DATOS..CLIENTAS
WHERE ---------------SUC= @suc and 
             NROREP = @nrorep
union 
select 0 as NROCLI, ' Todos' as vcden
order by vcden</CommandText>
        <QueryParameters>
          <QueryParameter Name="@nrorep">
            <Value>=Parameters!nrorep.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
    </DataSet>
    <DataSet Name="MES_ANIO">
      <Fields>
        <Field Name="orden">
          <DataField>orden</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="fecha">
          <DataField>fecha</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="mesanio">
          <DataField>mesanio</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
      <Query>
        <DataSourceName>DATOS_PARA_CTACTE</DataSourceName>
        <CommandText>SELECT  2 as orden,
--convert(smalldatetime,'01/'+replace(str(a.mes,2),' ','0')+'/'+str(b.anio,4),103) as fecha,
str(b.anio,4)+replace(str(a.mes,2),' ','0')+'01'as fecha,
'Canc. al '+replace(str(a.mes,2),' ','0')+'/'+str(b.anio,4) as mesanio
---SUBSTRING(CONVERT(CHAR(10),FECHA_FACT,111),1,7) AS ANIO_MES, 
---COMUNES.dbo.fecdia1(FECHA_FACT) AS fecha1
---STR(YEAR(FECHA_FACT),4) +'/'+REPLACE(STR(MONTH(FECHA_FACT),2),' ','0') AS ANIO
from
( select 1 as mes union
select 2 as mes union
select 3 as mes union
select 4 as mes union
select 5 as mes union
select 6 as mes union
select 7 as mes union
select 8 as mes union
select 9 as mes union
select 10 as mes union
select 11 as mes union
select 12 as mes
) a,
(
select distinct year(fecha_fact) as anio
FROM DATOS..FACTURAP
) b
where str(b.anio,4)+replace(str(a.mes,2),' ','0')+'01' &lt;= convert(char(8), getdate(),112)
union
select 1 as orden, 
--null as fecha, NO SE COMO PASARLO
STR(YEAR(GETDATE())+10,4)+'0101' AS FECHA, -- UNA FECHA MUY ADELANTADA
 '_Pendientes' as mesanio
ORDER BY 1,2 DESC</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
    </DataSet>
  </DataSets>
