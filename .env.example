# --- Conexión SQL Server ---
SQL_DRIVER=ODBC Driver 17 for SQL Server
SQL_SERVER=lariosql70
SQL_DATABASE=DATOS_COBRANZAS
SQL_USER=chat_app
SQL_PASSWORD=

# --- Proveedor LLM: "ollama" | "claude_haiku" (se puede elegir también desde la UI) ---
LLM_PROVIDER=ollama

# --- Ollama (local) ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b-instruct

# --- Claude Haiku (Anthropic, cloud) ---
# Obtener la key en https://console.anthropic.com
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

# --- Cache ---
CACHE_TTL_SECONDS=300
